# Required for image generation persistence and signed output URLs.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional but recommended so guest generations attach to a stable UUID.
NEXT_PUBLIC_GALLERY_USER_ID=

# Required for GPT OSS prompt planning via Cerebras.
CEREBRAS_API_KEY=

# Optional if you still want the legacy Anthropic prompt fallback route available.
ANTHROPIC_API_KEY=

# Recommended primary image backend for durable direct Gemini generation.
GOOGLE_CLOUD_API_KEY=
NANO_BANANA_API_KEY=

# Optional if you want to override the fallback hosted Cloud Run image worker.
GOOGLE_CLOUD_RUN_GENERATE_IMAGE_URL=
NEXT_PUBLIC_GOOGLE_CLOUD_RUN_GENERATE_IMAGE_URL=
CLOUD_RUN_SECRET_TOKEN=
